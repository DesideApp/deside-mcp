MCP_BASE_URL=http://localhost:3100
MCP_PATH=/mcp

# legacy | oauth
AUTH_MODE=legacy
AUTH_LOGIN_PATH=/auth/login
# Optional fallback only for legacy mode if /auth/nonce does not return domain.
AUTH_DOMAIN=http://localhost:3000

# Optional: if empty, script generates ephemeral wallet each run.
# AGENT_SECRET_KEY_B58=

# Optional test target for send_dm.
# TO_WALLET=
TEXT=hello from deside mini-agent

LIST_LIMIT=20
READ_LIMIT=20

# 1 to wait for notifications/dm_received over SSE
WATCH_PUSH=0
PUSH_TIMEOUT_MS=15000

OAUTH_SCOPE=dm:read dm:write
OAUTH_CLIENT_NAME=deside-mini-agent
# Optional: defaults to {MCP_BASE_URL}/mini-agent/callback
# OAUTH_REDIRECT_URI=
